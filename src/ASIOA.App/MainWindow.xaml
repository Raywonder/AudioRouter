<Window x:Class="ASIOA.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       
        Title="ASIOA Audio Router"
        Width="980"
        Height="680"
        MinWidth="820"
        MinHeight="560">
  <DockPanel Margin="12">
    <Menu DockPanel.Dock="Top" AutomationProperties.Name="ASIOA menu bar">
      <MenuItem Header="_File">
        <MenuItem Header="_Settings" InputGestureText="Ctrl+," Click="Settings_Click" />
        <Separator />
        <MenuItem Header="_Save settings" InputGestureText="Ctrl+S" Click="SaveSettings_Click" />
        <Separator />
        <MenuItem Header="E_xit" Click="Exit_Click" />
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="_Routes" IsCheckable="True" IsChecked="True" />
        <MenuItem Header="_Diagnostics" IsCheckable="True" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="_ASIOA Help" InputGestureText="F1" Click="Help_Click" />
      </MenuItem>
    </Menu>

    <StatusBar DockPanel.Dock="Bottom">
      <TextBlock x:Name="StatusText"
                 Text="ASIOA control app ready. Native ASIO driver is not installed in this release."
                 AutomationProperties.Name="Status: ASIOA control app ready. Native ASIO driver is not installed in this release." />
    </StatusBar>

    <TabControl AutomationProperties.Name="ASIOA Audio Router tabs">
      <TabItem Header="Routing">
        <Grid Margin="0,12,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="1.4*" />
          </Grid.ColumnDefinitions>

          <GroupBox Header="DAW Inputs" Margin="0,0,8,0">
            <ListView x:Name="InputsList"
                      AutomationProperties.Name="DAW input channels"
                      AutomationProperties.HelpText="Channels that ASIOA sends into the DAW."
                      DisplayMemberPath="AccessibleName" />
          </GroupBox>

          <GroupBox Header="DAW Outputs" Grid.Column="1" Margin="0,0,8,0">
            <ListView x:Name="OutputsList"
                      AutomationProperties.Name="DAW output channels"
                      AutomationProperties.HelpText="Channels that the DAW sends into ASIOA."
                      DisplayMemberPath="AccessibleName" />
          </GroupBox>

          <GroupBox Header="Routes" Grid.Column="2">
            <DockPanel>
              <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Add safe route"
                        Click="AddSafeRoute_Click"
                        AutomationProperties.Name="Add safe route" />
                <Button Content="Test feedback guard"
                        Margin="8,0,0,0"
                        Click="TestFeedbackGuard_Click"
                        AutomationProperties.Name="Test feedback guard" />
              </StackPanel>
              <ListView x:Name="RoutesList"
                        AutomationProperties.Name="Configured routes"
                        AutomationProperties.HelpText="Accessible list of audio routes, including enabled, mute, monitor, and gain state."
                        DisplayMemberPath="AccessibleSummary" />
              <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="Mute or unmute route"
                        Click="MuteRoute_Click"
                        AutomationProperties.Name="Mute or unmute selected route" />
                <Button Content="Volume down 5 percent"
                        Margin="8,0,0,0"
                        Click="RouteVolumeDown_Click"
                        AutomationProperties.Name="Lower selected route volume by 5 percent" />
                <Button Content="Volume up 5 percent"
                        Margin="8,0,0,0"
                        Click="RouteVolumeUp_Click"
                        AutomationProperties.Name="Raise selected route volume by 5 percent" />
                <Button Content="Remove route"
                        Margin="8,0,0,0"
                        Click="RemoveRoute_Click"
                        AutomationProperties.Name="Remove selected route" />
              </StackPanel>
            </DockPanel>
          </GroupBox>
        </Grid>
      </TabItem>

      <TabItem Header="Monitoring">
        <StackPanel Margin="0,12,0,0">
          <CheckBox x:Name="MonitoringCheckBox"
                    Content="Monitor directly in ASIOA"
                    IsChecked="True"
                    Checked="SettingsControl_Changed"
                    Unchecked="SettingsControl_Changed"
                    AutomationProperties.Name="Monitor directly in ASIOA" />
          <CheckBox x:Name="BypassCheckBox"
                    Content="Bypass ASIOA monitoring and route through DAW only"
                    Margin="0,8,0,0"
                    Checked="SettingsControl_Changed"
                    Unchecked="SettingsControl_Changed"
                    AutomationProperties.Name="Bypass ASIOA monitoring and route through DAW only" />
          <TextBlock Text="Monitoring mode is saved in the routing model. Live audio monitoring requires the native ASIOA audio engine."
                     Margin="0,16,0,0" />
        </StackPanel>
      </TabItem>

      <TabItem Header="Buffering">
        <StackPanel Margin="0,12,0,0" MaxWidth="420" HorizontalAlignment="Left">
          <TextBlock Text="Sample rate:" />
          <ComboBox x:Name="SampleRateComboBox"
                    AutomationProperties.Name="Sample rate"
                    AutomationProperties.HelpText="Audio engine sample rate."
                    SelectionChanged="SettingsControl_Changed"
                    Margin="0,4,0,12" />
          <TextBlock Text="Buffer size:" />
          <ComboBox x:Name="BufferSizeComboBox"
                    AutomationProperties.Name="Buffer size"
                    AutomationProperties.HelpText="Audio engine buffer size in samples."
                    SelectionChanged="SettingsControl_Changed"
                    Margin="0,4,0,12" />
          <TextBlock Text="Per-route volume, mute, and monitoring controls are represented in the route model and route list." />
        </StackPanel>
      </TabItem>

      <TabItem Header="Startup">
        <StackPanel Margin="0,12,0,0">
          <CheckBox x:Name="RunOnStartupCheckBox"
                    Content="Run ASIOA when Windows starts"
                    Checked="SettingsControl_Changed"
                    Unchecked="SettingsControl_Changed"
                    AutomationProperties.Name="Run ASIOA when Windows starts" />
          <CheckBox x:Name="StartMinimizedCheckBox"
                    Content="Start minimized to system tray"
                    IsChecked="True"
                    Margin="0,8,0,0"
                    Checked="SettingsControl_Changed"
                    Unchecked="SettingsControl_Changed"
                    AutomationProperties.Name="Start minimized to system tray" />
          <CheckBox x:Name="KeepEngineActiveCheckBox"
                    Content="Keep audio engine active when window is closed"
                    IsChecked="True"
                    Margin="0,8,0,0"
                    Checked="SettingsControl_Changed"
                    Unchecked="SettingsControl_Changed"
                    AutomationProperties.Name="Keep audio engine active when window is closed" />
        </StackPanel>
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>


